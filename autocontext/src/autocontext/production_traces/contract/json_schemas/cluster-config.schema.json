{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocontext.dev/schema/production-traces/cluster-config.json",
  "title": "ClusterConfig",
  "description": "Rule-based clustering config (Tier 2 per spec §8.1). First-matching rule wins; a catch-all with `default: true` is required.",
  "type": "object",
  "additionalProperties": false,
  "required": ["strategy", "rules"],
  "properties": {
    "strategy": { "type": "string", "const": "rules" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "match"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "match": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "equals": {},
                "contains": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } }
                  ]
                },
                "default": { "type": "boolean", "const": true }
              }
            }
          }
        }
      }
    }
  }
}
