{
  "name": "autoctx",
  "version": "0.4.4",
  "description": "autocontext — always-on agent evaluation harness",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/control-plane/actuators/**"
  ],
  "_sideEffects_false_subpaths": [
    "./production-traces/**",
    "./integrations/_shared/**",
    "./integrations/openai/**",
    "./integrations/anthropic/**"
  ],
  "files": [
    "README.md",
    "dist",
    "dashboard",
    "migrations"
  ],
  "keywords": [
    "agents",
    "autocontext",
    "evaluation",
    "harness",
    "llm",
    "mcp"
  ],
  "bin": {
    "autoctx": "dist/cli/index.js",
    "autocontext": "dist/cli/autocontext-shim.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./control-plane/runtime": {
      "import": "./dist/control-plane/runtime/index.js",
      "types": "./dist/control-plane/runtime/index.d.ts"
    },
    "./production-traces": {
      "types": "./dist/production-traces/sdk/index.d.ts",
      "import": "./dist/production-traces/sdk/index.js",
      "require": "./dist/cjs/production-traces/sdk/index.cjs"
    },
    "./integrations/_shared": {
      "types": "./dist/integrations/_shared/index.d.ts",
      "import": "./dist/integrations/_shared/index.js",
      "require": "./dist/cjs/integrations/_shared/index.cjs"
    },
    "./integrations/anthropic": {
      "types": "./dist/integrations/anthropic/index.d.ts",
      "import": "./dist/integrations/anthropic/index.js",
      "require": "./dist/cjs/integrations/anthropic/index.cjs"
    },
    "./integrations/openai": {
      "types": "./dist/integrations/openai/index.d.ts",
      "import": "./dist/integrations/openai/index.js",
      "require": "./dist/cjs/integrations/openai/index.cjs"
    },
    "./detectors/openai-python": {
      "types": "./dist/control-plane/instrument/detectors/openai-python/index.d.ts",
      "import": "./dist/control-plane/instrument/detectors/openai-python/index.js",
      "require": "./dist/cjs/control-plane/instrument/detectors/openai-python/index.cjs"
    },
    "./detectors/openai-ts": {
      "types": "./dist/control-plane/instrument/detectors/openai-ts/index.d.ts",
      "import": "./dist/control-plane/instrument/detectors/openai-ts/index.js",
      "require": "./dist/cjs/control-plane/instrument/detectors/openai-ts/index.cjs"
    },
    "./detectors/anthropic-python": {
      "types": "./dist/control-plane/instrument/detectors/anthropic-python/index.d.ts",
      "import": "./dist/control-plane/instrument/detectors/anthropic-python/index.js",
      "require": "./dist/cjs/control-plane/instrument/detectors/anthropic-python/index.cjs"
    },
    "./detectors/anthropic-ts": {
      "types": "./dist/control-plane/instrument/detectors/anthropic-ts/index.d.ts",
      "import": "./dist/control-plane/instrument/detectors/anthropic-ts/index.js",
      "require": "./dist/cjs/control-plane/instrument/detectors/anthropic-ts/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && npm run build:production-traces-sdk-cjs",
    "build:production-traces-sdk-cjs": "node scripts/build-production-traces-sdk-cjs.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "example:repl": "node examples/run-repl-session.mjs",
    "build:production-traces-types": "node scripts/generate-production-traces-types.mjs",
    "sync:production-traces-schemas": "node scripts/sync-python-production-traces-schemas.mjs",
    "check:production-traces-schemas": "node scripts/generate-production-traces-types.mjs --check && node scripts/sync-python-production-traces-schemas.mjs --check",
    "check:instrument-schemas": "node scripts/check-instrument-schemas.mjs --check",
    "check:schemas": "npm run check:production-traces-schemas && npm run check:instrument-schemas",
    "check:sdk-import-discipline": "node scripts/check-sdk-import-discipline.mjs",
    "check:production-traces-sdk-bundle-size": "node scripts/check-production-traces-sdk-bundle-size.mjs",
    "check:side-effects": "node scripts/check-side-effects.mjs",
    "check:license-compatibility": "node scripts/check-license-compatibility.mjs",
    "check:no-postinstall-scripts": "node scripts/check-no-postinstall-scripts.mjs",
    "check:no-telemetry": "node scripts/check-no-telemetry.mjs",
    "check:integrations-openai-bundle-size": "node scripts/check-integrations-openai-bundle-size.mjs",
    "check:integrations-anthropic-bundle-size": "node scripts/check-integrations-anthropic-bundle-size.mjs",
    "check:a2-ii-a-all": "npm run check:sdk-import-discipline && npm run check:side-effects && npm run check:production-traces-sdk-bundle-size && npm run check:license-compatibility && npm run check:no-postinstall-scripts && npm run check:no-telemetry",
    "regenerate-cross-runtime-fixtures": "node scripts/regenerate-cross-runtime-fixtures.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greyhaven-ai/autocontext.git"
  },
  "homepage": "https://github.com/greyhaven-ai/autocontext/tree/main/ts",
  "bugs": {
    "url": "https://github.com/greyhaven-ai/autocontext/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.32",
    "openai": "^4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.13",
    "fast-check": "^4.7.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/diff": "^7.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.0.0",
    "diff": "^9.0.0",
    "ignore": "5.3.2",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4",
    "react": "^18.3.1",
    "secure-exec": "^0.1.0",
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.21.4",
    "tree-sitter-python": "0.21.0",
    "tree-sitter-typescript": "0.21.2",
    "ulid": "^3.0.2",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  }
}
