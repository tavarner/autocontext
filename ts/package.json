{
  "name": "@greyhaven/autoctx",
  "version": "0.1.0",
  "description": "AutoContext — always-on agent evaluation harness",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "autoctx": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
